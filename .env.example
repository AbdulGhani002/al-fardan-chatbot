# Copy to .env and fill in real values before deploying.

# HTTP
HOST=0.0.0.0
PORT=8001

# Shared secret — the CRM passes this as `x-chatbot-secret` when calling
# /admin/* endpoints. Generate with:  openssl rand -base64 36 | tr -d '=+/\n' | cut -c1-40
CHATBOT_SECRET=change-me

# Calls from the chatbot back to the CRM (e.g. completed signup leads)
CRM_BASE_URL=https://al-fardan-crm.vercel.app
CRM_API_KEY=change-me

# Retrieval
CONFIDENCE_THRESHOLD=0.22
TOP_K=3

# CORS — comma-separated origins that may call /chat from the browser
CORS_ORIGINS=https://al-fardan-crm.vercel.app,http://localhost:3000

# ─── RAG / Generative layer ────────────────────────────────────
# Empty = retrieval-only (bot returns KB entries verbatim).
# Set to "genspark" to route through Genspark.ai's OpenAI-
# compatible API (primary choice per the Apr-22 brief).
# Other values: openai_compatible, openai, groq, ollama.
GENERATOR_BACKEND=genspark

# OpenAI-compatible backend — Genspark / OpenAI / Groq / Together.
# Never commit the key — populate via .env (gitignored) on the VPS.
OPENAI_API_BASE=https://api.genspark.ai/v1
OPENAI_API_KEY=your-genspark-or-openai-key
OPENAI_MODEL=gpt-4o-mini

# Ollama (only when GENERATOR_BACKEND=ollama)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M

# Per-request LLM timeout (seconds)
RAG_TIMEOUT_S=40
