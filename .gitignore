__pycache__/
*.py[cod]
*.egg-info/
.venv/
.env
app/data/index.pkl
app/data/chat.db
# Scraped KB files ARE committed — they represent a specific scrape
# snapshot and we want the VPS build to ship identical content without
# needing outbound HTTPS to ethereum.org / bitcoin.org / wikipedia
# during container rebuild. Re-run scrapers locally when refreshing.
.pytest_cache/
dist/
build/

# Staged FAQ source files — keep the ingest script + .gitkeep but
# not the large source corpus (lives in Downloads, re-stage when
# needed via `cp ~/Downloads/chatbot.zip extract...`).
scripts/incoming_faqs/*
!scripts/incoming_faqs/.gitkeep
