# Keep build context lean + prevent stale runtime data from
# leaking into new images.
.git/
.gitignore
.pytest_cache/
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env
.env.local
.env.*.local

# Runtime state — rebuilt fresh inside the image
app/data/index.pkl
app/data/chat.db
app/data/*.sqlite*

# Scraped KB chunks — regenerated by scrapers, not source-of-truth
app/data/kb/scraped_*.jsonl

# Editor / OS cruft
.idea/
.vscode/
.DS_Store
Thumbs.db

# Dev-only
tests/__pycache__/
*.log
